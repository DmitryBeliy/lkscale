# ============================================
# Lkscale ERP - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# ============================================

# ============================================
# App Configuration
# ============================================
# App Variant (development | preview | production)
APP_VARIANT=development

# App Name (optional, for branding)
APP_NAME=Lkscale ERP

# ============================================
# Supabase Configuration
# ============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

# Required for all environments
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key - ONLY for server-side/admin operations
# WARNING: Keep this secret! Never expose in client code.
# Used in: scripts/setup-supabase.js, edge functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Demo Mode Configuration
# ============================================
# Password for demo account (demo@lkscale.app)
# Required for demo login functionality
# Generate a secure password for production
EXPO_PUBLIC_DEMO_PASSWORD=your-secure-demo-password

# Database URL (for direct PostgreSQL connections)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# ============================================
# Expo / EAS Configuration
# ============================================
# EAS Project ID (from expo.dev)
EAS_PROJECT_ID=your-eas-project-id

# Expo Access Token for CI/CD
# Get from: https://expo.dev/settings/access-tokens
EXPO_TOKEN=your-expo-token

# ============================================
# AI Services Configuration
# ============================================
# OpenAI API Key (for AI insights)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude API Key (alternative AI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ============================================
# Analytics & Monitoring
# ============================================
# Amplitude Analytics
AMPLITUDE_API_KEY=your-amplitude-key

# Mixpanel Analytics
MIXPANEL_TOKEN=your-mixpanel-token

# Sentry Error Tracking
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ============================================
# Push Notifications
# ============================================
# Firebase Cloud Messaging
FIREBASE_CLOUD_MESSAGING_TOKEN=your-fcm-token

# OneSignal (alternative)
ONESIGNAL_APP_ID=your-onesignal-app-id

# ============================================
# Payment Providers
# ============================================
# Stripe (for online payments)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# YooKassa (for Russian market)
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# ============================================
# External APIs
# ============================================
# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# SMS Provider (Twilio)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMS Provider (SMS.ru)
SMSRU_API_ID=your-smsru-api-id

# ============================================
# Feature Flags
# ============================================
# Enable/Disable features
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_AI_INSIGHTS=true
ENABLE_OFFLINE_MODE=true
ENABLE_BIOMETRIC_AUTH=false

# ============================================
# Development Settings
# ============================================
# API timeout in milliseconds
API_TIMEOUT=30000

# Cache duration in minutes
CACHE_DURATION_MINUTES=5

# Enable debug logging
DEBUG_LOGGING=true

# ============================================
# Local Development (Supabase Local)
# ============================================
# Use these for local Supabase development
# LOCAL_SUPABASE_URL=http://localhost:54321
# LOCAL_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# Deployment
# ============================================
# Vercel (for web deployments)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# ============================================
# Security
# ============================================
# JWT Secret (if using custom auth)
JWT_SECRET=your-jwt-secret-min-32-chars-long

# Encryption key for sensitive data
ENCRYPTION_KEY=your-encryption-key-32chars!!

# ============================================
# Notes
# ============================================
# 1. Never commit .env file to git
# 2. Use different keys for development and production
# 3. Rotate keys regularly
# 4. Use strong passwords and secrets
# 5. Enable 2FA on all services
# ============================================
